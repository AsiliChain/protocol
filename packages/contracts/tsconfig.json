{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./contracts",
    "resolveJsonModule": true
  },
  "include": ["contracts/**/*", "scripts/**/*", "test/**/*", "hardhat.config.ts"],
  "files": ["hardhat.config.ts"]
}